@{
    ViewData["Title"] = "Product Listing";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-3 d-none d-lg-block">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Category</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-decoration-none text-dark">Mobile accessory</a></li>
                        <li><a href="#" class="text-decoration-none text-dark">Electronics</a></li>
                        <li><a href="#" class="text-decoration-none text-dark">Smartphones</a></li>
                    </ul>
                    <hr />
                    <h6 class="fw-bold mb-3">Brands</h6>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="brand1">
                        <label class="form-check-label" for="brand1">Samsung</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="brand2">
                        <label class="form-check-label" for="brand2">Apple</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3 bg-white p-2 border rounded shadow-sm">
                <span>12,511 items in <strong>Mobile accessory</strong></span>
                <div>
                    <select class="form-select d-inline-block w-auto">
                        <option>Featured</option>
                        <option>Price: Low to High</option>
                    </select>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-md-3 g-4">
                @for (int i = 1; i <= 6; i++)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0">
                            <img src="~/images/product@(i).jpg" class="card-img-top p-3" alt="Product" onerror="this.src='https://via.placeholder.com/200'">
                                <div class="card-body">
                                    <h6 class="fw-bold text-primary">$99.50</h6>
                                    <p class="card-text small mb-1 text-muted">GoPro HERO6 4K Action Camera - Black</p>
                                    <div class="text-warning small mb-2">
                                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i> 7.5
                                    </div>
                                    <button class="btn btn-outline-primary btn-sm w-100">View details</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>