@model IEnumerable<ecommerce_website.Models.Product>

<div class="container-fluid mt-4">
    <div class="row">
        <aside class="col-md-3">
            <div class="bg-white border-end pe-3" style="min-height: 100vh;">
                <div class="mb-4">
                    <h6 class="fw-bold mb-2">Category</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Electronics</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Smartphones</a></li>
                        <li><a href="#" class="text-primary text-decoration-none small">See all</a></li>
                    </ul>
                </div>
                <hr class="text-muted">
                <div class="mb-4">
                    <h6 class="fw-bold mb-2">Brands</h6>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="samsung" checked>
                        <label class="form-check-label" for="samsung">Samsung</label>
                    </div>
                    <a href="#" class="text-primary text-decoration-none small">See all</a>
                </div>
            </div>
        </aside>

        <main class="col-md-9">
            <header class="d-flex justify-content-between align-items-center mb-3">
                <span>@Model.Count() items found</span>
                <div class="d-flex align-items-center">
                    <select class="form-select w-auto me-2">
                        <option>Featured</option>
                    </select>
                </div>
            </header>

            <div class="row row-cols-1 row-cols-md-3 g-3">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="d-flex align-items-center justify-content-center p-3" style="height: 180px; background-color: #f8f9fa;">
                                <img src="~/@item.ImageName" class="img-fluid" style="max-height: 100%;" alt="@item.Name"
                                     onerror="this.src='/images/no-image.png';">
                                </div>
                                <div class="card-body p-2 text-center">
                                    <h6 class="mb-1 text-dark fw-bold">$@item.Price</h6>
                                    <p class="text-muted mb-2" style="font-size: 0.8rem;">@item.Name</p>
                                
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <a asp-controller="Cart" asp-action="Add" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Add to Cart</a>
                                        <button class="btn btn-outline-danger btn-sm rounded-circle"><i class="far fa-heart"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item"><a class="page-link" href="?page=1">1</a></li>
                        <li class="page-item"><a class="page-link" href="?page=2">2</a></li>
                        <li class="page-item"><a class="page-link" href="?page=3">3</a></li>
                    </ul>
                </nav>
            </main>
        </div>
    </div>